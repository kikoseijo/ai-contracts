{
  "name": "sunnyface/ai-contracts",
  "description": "Contratos DTO y esquemas compartidos entre Hub y Spoke",
  "type": "library",
  "require": {
    "php": "^8.4",
    "spatie/laravel-data": "^4.20",
    "illuminate/contracts": "^12.0",
    "illuminate/support": "^12.0|^13.0"
  },
  "autoload": {
    "psr-4": {
      "Sunnyface\\Contracts\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Sunnyface\\Contracts\\AiContractsServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}