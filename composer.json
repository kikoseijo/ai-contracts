{
  "name": "sunnyface/ai-contracts",
  "version": "1.2.5",
  "description": "Contratos DTO y esquemas compartidos entre Hub y Spoke",
  "type": "library",
  "require": {
    "php": "^8.4",
    "spatie/laravel-data": "^4.0",
    "illuminate/contracts": "^12.0|^13.0",
    "illuminate/http": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "mallardduck/blade-lucide-icons": "^1.26"
  },
  "autoload": {
    "psr-4": {
      "Sunnyface\\Contracts\\": "src/",
      "Sunnyface\\AiContracts\\Support\\": "src/Support/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Sunnyface\\Contracts\\AiContractsServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "pestphp/pest": "^4.4",
    "orchestra/testbench": "^11.0",
    "pestphp/pest-plugin-laravel": "^4.1"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}